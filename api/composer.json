{
    "name": "harmonia-education/humanome-api",
    "description": "humanome.xyz API — competence cartography platform (RESPIRE ecosystem)",
    "license": "AGPL-3.0-only",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "maxmind-db/reader": "^1.13",
        "opis/json-schema": "^2.4",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Humanome\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Humanome\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        },
        "sort-packages": true
    }
}
