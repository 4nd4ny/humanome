# humanome.xyz — variables d'environnement de l'API.
#
# En dev : copier en api/.env (chargé par Bootstrap si présent).
# En prod OVH : ces variables vivent dans ~/app/shared/.env, HORS webroot
# (ADR-008) — jamais dans le dépôt, jamais dans www/. Vérifié : /app/shared/.env
# répond 403 en HTTP.
#
# Générer un secret : openssl rand -hex 32

# --- Application ------------------------------------------------------------
APP_ENV=production          # "dev" active les détails d'erreur Slim (jamais en prod)
# APP_VERSION=              # sinon lue depuis le fichier VERSION de la release, sinon "dev"

# --- Base de données (MySQL 8, utf8mb4) -------------------------------------
DB_HOST=example123.mysql.db
DB_NAME=example123
DB_USER=example123
DB_PASSWORD=change-me

# --- Opérations à distance (déploiement sans SSH, ADR-008) ------------------
# Jeton des endpoints /api/admin/{migrate,import-referentiel,import-prompt-package,
# grant-role,default-package,maintenance,worker-tick}. Long et secret.
MIGRATE_TOKEN=change-me-long-random

# --- LLM plateforme (démo publique + service humanome) ----------------------
ANTHROPIC_API_KEY=sk-ant-change-me

# --- Preuve de travail de la démo (sinon dérivée de MIGRATE_TOKEN) ----------
POW_SECRET=change-me-random

# --- PayPal (recharge du crédit prépayé Twin_v9, ADR-010 §3) -----------------
# Flux Orders v2 en redirection, serveur-à-serveur uniquement : aucune donnée
# bancaire ne transite ni n'est stockée chez nous. Tant que ces variables sont
# absentes, les routes de recharge répondent 503 et l'interface affiche
# « recharge indisponible ». Credentials créés sur developer.paypal.com.
# PAYPAL_MODE=sandbox            # sandbox (api-m.sandbox.paypal.com) ou live
# PAYPAL_CLIENT_ID=change-me
# PAYPAL_SECRET=change-me

# --- Chiffrement au repos des clés API personnelles / établissement ---------
# libsodium crypto_secretbox. hex de 64 caractères (32 octets).
SODIUM_MASTER_KEY=change-me-64-hex-chars

# --- Réglages de la démo publique (config/demo.php surchargée par env) ------
DEMO_ENABLED=true
DEMO_PROVIDER=anthropic
DEMO_MODEL=claude-sonnet-5
DEMO_MAX_TOKENS_PER_REQUEST=8192
DEMO_MAX_INPUT_CHARS=20000
DEMO_PER_IP_PER_HOUR=40
DEMO_DAILY_GLOBAL_TOKENS=2000000
DEMO_DAILY_BUDGET_USD=10
DEMO_POW_DIFFICULTY_BITS=16
DEMO_UPSTREAM_TIMEOUT=150
