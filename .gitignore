# Dependencies
node_modules/
vendor/

# Builds
dist/
web/dist/
*.local

# Environments & secrets — never commit
.env
.env.*
!.env.example
!.env.deploy.example
.env.deploy
*.key
api-key*.txt
secrets/

# Golden Prompt — private by design (cahier §7)
assets-existants/golden-prompt/

# Twin9 — les GABARITS sont confidentiels (ADR-010) : jamais dans le dépôt.
# Source locale : ../Twin9 (hors repo). Oracles de parité générés à la
# demande (scripts/twin9/gen-oracles.sh) dans engine/test/twin9-oracles/.
golden-twin9/
engine/test/twin9-oracles/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Test artifacts
coverage/
playwright-report/
test-results/

# PHP
composer.phar
.phpunit.result.cache
web/public/data/
build/
backups/
web/.claude/

# Digest de doc de l'assistant tuteur : généré (build-tuteur-digest.mjs),
# régénéré à chaque stage-api — comme les prompt-packages, on ne versionne
# que le générateur, pas l'artefact (évite la dérive avec nav.js/content).
scripts/data/tuteur-digest.md

# Python (générateurs de vecteurs) — jamais versionner les caches compilés
# (ils embarquent le chemin absolu local de la machine qui les a produits).
__pycache__/
*.pyc
